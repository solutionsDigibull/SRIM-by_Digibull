# ---- Dependencies (regenerated by INSTALL.bat / Docker) ----
node_modules/

# ---- Temporary backups of nested git repos (created during the initial push) ----
**/_GITDIR_BACKUP_/

# ---- OS cruft ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Local pnpm store ----
.pnpm-store/

# ---- Editor/script backups & one-time markers ----
*.bak
.unblocked
daemon-test.log
